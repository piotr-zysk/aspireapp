{
  "$schema": "https://json.schemastore.org/aspire-8.0.json",
  "resources": {
    "sqlserver": {
      "type": "container.v0",
      "connectionString": "Server={sqlserver.bindings.tcp.host},{sqlserver.bindings.tcp.port};User ID=sa;Password={sqlserver-password.value};TrustServerCertificate=true",
      "image": "mcr.microsoft.com/mssql/server:2022-latest",
      "volumes": [
        {
          "name": "apphost-feed4158f1-sqlserver-data",
          "target": "/var/opt/mssql",
          "readOnly": false
        }
      ],
      "env": {
        "ACCEPT_EULA": "Y",
        "MSSQL_SA_PASSWORD": "{sqlserver-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 1433
        }
      }
    },
    "appdb": {
      "type": "value.v0",
      "connectionString": "{sqlserver.connectionString};Initial Catalog=appdb"
    },
    "apiservice": {
      "type": "project.v0",
      "path": "../ApiService/ApiService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{apiservice.bindings.http.targetPort}",
        "ConnectionStrings__appdb": "{appdb.connectionString}",
        "APPDB_HOST": "{sqlserver.bindings.tcp.host}",
        "APPDB_PORT": "{sqlserver.bindings.tcp.port}",
        "APPDB_USERNAME": "sa",
        "APPDB_PASSWORD": "{sqlserver-password.value}",
        "APPDB_URI": "mssql://sa:{sqlserver-password.value}@{sqlserver.bindings.tcp.host}:{sqlserver.bindings.tcp.port}/appdb",
        "APPDB_JDBCCONNECTIONSTRING": "jdbc:sqlserver://{sqlserver.bindings.tcp.host}:{sqlserver.bindings.tcp.port};trustServerCertificate=true;databaseName=appdb",
        "APPDB_DATABASENAME": "appdb"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "sqlserver-password": {
      "type": "parameter.v0",
      "value": "{sqlserver-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "minLower": 1,
              "minUpper": 1,
              "minNumeric": 1
            }
          }
        }
      }
    },
    "sqlserver-password-uri-encoded": {
      "type": "annotated.string",
      "value": "{sqlserver-password.value}",
      "filter": "uri"
    }
  }
}